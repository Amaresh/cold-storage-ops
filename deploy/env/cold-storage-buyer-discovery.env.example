# Core preview configuration used by run.py
BUYER_DISCOVERY_STARTER_TOWNS=Guntur
BUYER_DISCOVERY_QUERY_SEEDS=chilli wholesaler,gunj shop

# Reserved for backend ingestion wiring
BUYER_DISCOVERY_BACKEND_BASE_URL=http://127.0.0.1:9090
BUYER_DISCOVERY_INTERNAL_API_HEADER=X-API-Key
# BUYER_DISCOVERY_INTERNAL_API_KEY is injected from /etc/cold-storage-backend.env during deploy when available.

# Optional host capability checks for future browser/VPN-backed runs
BUYER_DISCOVERY_REQUIRE_NORDVPN=false
BUYER_DISCOVERY_REQUIRE_BROWSER=false
BUYER_DISCOVERY_BROWSER_BIN=chromium-browser
